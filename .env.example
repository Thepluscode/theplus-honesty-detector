# theplus-honesty-detector — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The audit tools in tools/ are mostly self-contained (no env required).
# The only tool that needs credentials is tools/alpha_zoo/alpaca_to_csv.py
# for fetching Alpaca market data.

# === Alpaca (optional — only needed for alpha_zoo/alpaca_to_csv.py) ===
# Preferred: create tools/alpha_zoo/alpaca_credentials.json (see README)
# Fallback env vars if the JSON file is absent:
APCA_API_KEY_ID=your-alpaca-api-key
APCA_API_SECRET_KEY=your-alpaca-api-secret
